# Copy this file to .env and fill in the values.  NEVER commit .env to git.
COMPOSE_PROJECT_NAME=krakenbot

# ── Kraken API keys ──────────────────────────────────────────────────────────
# Leave EMPTY for dry-run (paper trading). When going live, create the key at
# kraken.com → Settings → API with permissions: Query Funds, Create & Modify
# Orders, Cancel Orders.  DO NOT grant Withdraw permission.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# ── FreqUI / REST API credentials (also used by the companion service) ───────
FREQTRADE__API_SERVER__USERNAME=freqtrader
FREQTRADE__API_SERVER__PASSWORD=change_me_strong_password
FREQTRADE__API_SERVER__JWT_SECRET_KEY=change_me_long_random_string
FREQTRADE__API_SERVER__WS_TOKEN=change_me_other_random_string

# ── Telegram bot (ONE bot for everything: alerts + trades + settings) ────────
# Create it with @BotFather; get your numeric chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids allowed to use the bot, e.g. 123456789
TELEGRAM_CHAT_IDS=

# ── Google Sheets tax log (optional but recommended) ─────────────────────────
# Path is inside the companion container; put the downloaded service-account
# json at config/google-service-account.json (it is git-ignored).
GOOGLE_SHEETS_CREDENTIALS_FILE=/app/config/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Strategy selection ───────────────────────────────────────────────────────
# Which strategy the bot trades with (paper or live). Available:
#   KrakenSpotStrategy  - conservative 1h trend-pullback (default)
#   E0V1EKraken         - community E0V1E scalper adapted for Kraken fees, 15m
# After changing, restart with: bash scripts/start.sh
STRATEGY=KrakenSpotStrategy

# ── Companion tuning (defaults are fine) ─────────────────────────────────────
FREQTRADE_API_URL=http://freqtrade:8080
TAX_LOG_POLL_SECONDS=300
CAPITAL_POLL_SECONDS=300
